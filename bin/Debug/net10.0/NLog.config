
<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true"
      internalLogLevel="Trace"
      internalLogFile="/tmp/nlog-internal.log">

    <extensions>
        <add assembly="NLog.Loki" />
    </extensions>

    <targets>
        <target xsi:type="Console"
                name="console"
                layout="${longdate} [${level:uppercase=true}] ${logger:shortName=true}: ${message} ${exception:format=tostring}" />

        <target xsi:type="Loki"
                name="loki"
                endpoint="http://haav-loki:3100">
            <label name="service" layout="personaltrainer-service" />
            <label name="level" layout="${level:lowercase=true}" />
        </target>
    </targets>

    <rules>
        <logger name="Microsoft.*" maxlevel="Info" final="true" />
        <logger name="*" minlevel="Info" writeTo="console,loki" />
    </rules>

</nlog>
