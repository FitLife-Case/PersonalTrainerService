<!DOCTYPE html>
<html lang="da">
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FitLife Digital</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
</head>
<body style="background: linear-gradient(135deg, #FFFFFF 0%, #EDE8F5 50%, #D8D0F0 100%); min-height: 100vh;">
    <nav class="navbar mb-4" style="background: rgba(255,255,255,0.8); backdrop-filter: blur(10px); border-bottom: 1px solid rgba(107,53,217,0.1);">
            <a class="navbar-brand fw-bold" href="/" style="color: #6B35D9;">⚡ FitLife Digital</a>
    <main>
        @RenderBody()
    </main>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
