@page
@model IndexModel
@{
    ViewData["Title"] = "Personal Trainer";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />

<div class="container mt-4">
    <h1 class="mb-4">FitLife - Personal Trainer</h1>

    <ul class="nav nav-tabs mb-4" id="mainTab">
        <li class="nav-item">
            <a class="nav-link active" data-bs-toggle="tab" href="#trainers">Traenere</a>
        </li>
        <li class="nav-item">
            <a class="nav-link" data-bs-toggle="tab" href="#trainingplans">Traeningsplaner</a>
        </li>
        <li class="nav-item">
            <a class="nav-link" data-bs-toggle="tab" href="#nutritionplans">Kostplaner</a>
        </li>
    </ul>

    <div class="tab-content">

        <div class="tab-pane fade show active" id="trainers">
            <div class="card p-3 mb-4">
                <h5>Opret traener</h5>
                <form method="post" asp-page-handler="CreateTrainer" action="/personaltrainer/">
                    <div class="row g-2">
                        <div class="col-md-6">
                            <input class="form-control" asp-for="NewTrainer.FirstName" placeholder="Fornavn" required />
                        </div>
                        <div class="col-md-6">
                            <input class="form-control" asp-for="NewTrainer.LastName" placeholder="Efternavn" required />
                        </div>
                        <div class="col-md-6">
                            <input class="form-control" asp-for="NewTrainer.Email" placeholder="Email" required />
                        </div>
                        <div class="col-md-6">
                            <input class="form-control" asp-for="NewTrainer.PhoneNumber" placeholder="Telefon" />
                        </div>
                        <div class="col-md-6">
                            <input class="form-control" asp-for="NewTrainer.YearsOfExperience" placeholder="Erfaringsaar" type="number" />
                        </div>
                        <div class="col-12">
                            <textarea class="form-control" asp-for="NewTrainer.Bio" placeholder="Bio" rows="2"></textarea>
                        </div>
                    </div>
                    <button class="btn btn-primary mt-2" type="submit">Opret</button>
                </form>
            </div>

            <div class="row">
                @foreach (var trainer in Model.Trainers)
                {
                    <div class="col-md-4 mb-3">
                        <div class="card h-100">
                            <div class="card-body">
                                <h5>@trainer.FirstName @trainer.LastName</h5>
                                <p class="text-muted">@trainer.Bio</p>
                                <p><strong>Email:</strong> @trainer.Email</p>
                                <p><strong>Telefon:</strong> @trainer.PhoneNumber</p>
                                <p><strong>Erfaring:</strong> @trainer.YearsOfExperience ar</p>
                                <p><strong>ID:</strong> @trainer.Id</p>
                                <span class="badge @(trainer.IsActive ? "bg-success" : "bg-danger")">
                                    @(trainer.IsActive ? "Aktiv" : "Inaktiv")
                                </span>
                            </div>
                            <div class="card-footer">
                                <form method="post" asp-page-handler="DeleteTrainer">
                                    <input type="hidden" name="id" value="@trainer.Id" />
                                    <button class="btn btn-sm btn-danger" type="submit">Slet</button>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>

        <div class="tab-pane fade" id="trainingplans">
            <div class="card p-3 mb-4">
                <h5>Soeg planer for traener</h5>
                <form method="get" asp-page-handler="TrainerPlans">
                    <div class="row g-2">
                        <div class="col-md-6">
                            <input class="form-control" name="trainerId" placeholder="Traener ID" required />
                        </div>
                        <div class="col-md-2">
                            <button class="btn btn-secondary" type="submit">Hent planer</button>
                        </div>
                    </div>
                </form>
            </div>

            <div class="card p-3 mb-4">
                <h5>Opret traeningsplan</h5>
                <form method="post" asp-page-handler="CreateTrainingPlan">
                    <div class="row g-2">
                        <div class="col-md-6">
                            <input class="form-control" name="NewTrainingPlan.TrainerId" placeholder="Traener ID" required />
                        </div>
                        <div class="col-md-6">
                            <input class="form-control" name="NewTrainingPlan.MemberId" placeholder="Medlem ID" required />
                        </div>
                        <div class="col-md-6">
                            <input class="form-control" asp-for="NewTrainingPlan.Name" placeholder="Plannavn" required />
                        </div>
                        <div class="col-md-6">
                            <input class="form-control" asp-for="NewTrainingPlan.Description" placeholder="Beskrivelse" />
                        </div>
                        <div class="col-md-6">
                            <input class="form-control" asp-for="NewTrainingPlan.StartDate" type="date" />
                        </div>
                        <div class="col-md-6">
                            <input class="form-control" asp-for="NewTrainingPlan.EndDate" type="date" />
                        </div>
                    </div>
                    <button class="btn btn-primary mt-2" type="submit">Opret</button>
                </form>
            </div>

            <div class="row">
                @foreach (var plan in Model.TrainingPlans)
                {
                    <div class="col-md-4 mb-3">
                        <div class="card h-100">
                            <div class="card-body">
                                <h5>@plan.Name</h5>
                                <p class="text-muted">@plan.Description</p>
                                <p><strong>Start:</strong> @plan.StartDate</p>
                                <p><strong>Slut:</strong> @plan.EndDate</p>
                                <span class="badge bg-info">@plan.Status</span>
                            </div>
                            <div class="card-footer">
                                <form method="post" asp-page-handler="DeleteTrainingPlan">
                                    <input type="hidden" name="id" value="@plan.Id" />
                                    <button class="btn btn-sm btn-danger" type="submit">Slet</button>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>

        <div class="tab-pane fade" id="nutritionplans">
            <div class="card p-3 mb-4">
                <h5>Soeg kostplaner for traener</h5>
                <form method="get" asp-page-handler="TrainerPlans">
                    <div class="row g-2">
                        <div class="col-md-6">
                            <input class="form-control" name="trainerId" placeholder="Traener ID" required />
                        </div>
                        <div class="col-md-2">
                            <button class="btn btn-secondary" type="submit">Hent kostplaner</button>
                        </div>
                    </div>
                </form>
            </div>

            <div class="card p-3 mb-4">
                <h5>Opret kostplan</h5>
                <form method="post" asp-page-handler="CreateNutritionPlan">
                    <div class="row g-2">
                        <div class="col-md-6">
                            <input class="form-control" name="NewNutritionPlan.TrainerId" placeholder="Traener ID" required />
                        </div>
                        <div class="col-md-6">
                            <input class="form-control" name="NewNutritionPlan.MemberId" placeholder="Medlem ID" required />
                        </div>
                        <div class="col-md-6">
                            <input class="form-control" asp-for="NewNutritionPlan.Name" placeholder="Plannavn" required />
                        </div>
                        <div class="col-md-6">
                            <input class="form-control" asp-for="NewNutritionPlan.DailyCalorieTarget" placeholder="Daglige kalorier" type="number" />
                        </div>
                        <div class="col-md-6">
                            <input class="form-control" asp-for="NewNutritionPlan.StartDate" type="date" />
                        </div>
                        <div class="col-md-6">
                            <input class="form-control" asp-for="NewNutritionPlan.EndDate" type="date" />
                        </div>
                    </div>
                    <button class="btn btn-primary mt-2" type="submit">Opret</button>
                </form>
            </div>

            <div class="row">
                @foreach (var plan in Model.NutritionPlans)
                {
                    <div class="col-md-4 mb-3">
                        <div class="card h-100">
                            <div class="card-body">
                                <h5>@plan.Name</h5>
                                <p><strong>Kalorier:</strong> @plan.DailyCalorieTarget kcal/dag</p>
                                <p><strong>Start:</strong> @plan.StartDate</p>
                                <p><strong>Slut:</strong> @plan.EndDate</p>
                                <span class="badge bg-info">@plan.Status</span>
                            </div>
                            <div class="card-footer">
                                <form method="post" asp-page-handler="DeleteNutritionPlan">
                                    <input type="hidden" name="id" value="@plan.Id" />
                                    <button class="btn btn-sm btn-danger" type="submit">Slet</button>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>

    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>